<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.text.Font?>

<GridPane hgap="10.0" maxHeight="-Infinity"
	maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
	styleClass="root" vgap="10.0"
	xmlns="http://javafx.com/javafx/8.0.60"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="org.eclipse.tradista.security.equity.ui.controller.EquityDefinitionController">
	<columnConstraints>
		<ColumnConstraints hgrow="SOMETIMES" />
	</columnConstraints>
	<rowConstraints>
		<RowConstraints vgrow="SOMETIMES" />
		<RowConstraints vgrow="SOMETIMES" />
	</rowConstraints>
	<children>
		<HBox maxHeight="-Infinity" maxWidth="-Infinity"
			minHeight="-Infinity" minWidth="-Infinity">
			<children>
				<Label fx:id="productType" styleClass="labelBold" maxHeight="-Infinity"
					maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</Label>
				<Label text="Load by product">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</Label>
				<ComboBox fx:id="loadingCriterion">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</ComboBox>
				<TextField fx:id="load" onAction="#load">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</TextField>
				<Button mnemonicParsing="false" onAction="#load" text="Load">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</Button>
				<Button mnemonicParsing="false" onAction="#save" text="Save">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</Button>
				<Button mnemonicParsing="false" onAction="#copy" text="Copy">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</Button>
				<Button mnemonicParsing="false" onAction="#clear" text="New">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</Button>
				<Button mnemonicParsing="false" onAction="#refresh"
					text="Refresh">
					<HBox.margin>
						<Insets right="10.0" />
					</HBox.margin>
				</Button>
			</children>
			<opaqueInsets>
				<Insets />
			</opaqueInsets>
		</HBox>
		<TabPane GridPane.rowIndex="1" tabClosingPolicy="UNAVAILABLE">
			<tabs>
				<Tab text="Main Details">
					<content>
						<GridPane hgap="10.0" maxHeight="-Infinity"
							maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
							vgap="10.0" GridPane.halignment="CENTER">
							<columnConstraints>
								<ColumnConstraints hgrow="SOMETIMES"
									minWidth="-Infinity" />
								<ColumnConstraints hgrow="SOMETIMES"
									minWidth="-Infinity" />
								<ColumnConstraints hgrow="SOMETIMES"
									minWidth="-Infinity" />
								<ColumnConstraints hgrow="SOMETIMES"
									minWidth="-Infinity" />
								<ColumnConstraints hgrow="SOMETIMES"
									minWidth="-Infinity" />
								<ColumnConstraints hgrow="SOMETIMES"
									minWidth="-Infinity" />
							</columnConstraints>
							<rowConstraints>
								<RowConstraints vgrow="SOMETIMES" />
								<RowConstraints vgrow="SOMETIMES" />
								<RowConstraints vgrow="SOMETIMES" />
								<RowConstraints vgrow="SOMETIMES" />
								<RowConstraints vgrow="SOMETIMES" />
								<RowConstraints vgrow="SOMETIMES" />
							</rowConstraints>
							<children>
				
								<Label styleClass="labelBold" maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Equity Id"/>
								<Label fx:id="productId" styleClass="labelBold" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="1"/>
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Issuer"
									GridPane.columnIndex="2" GridPane.rowIndex="4" />
								<ComboBox fx:id="issuer" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="3" GridPane.rowIndex="4">
									<items>
										<FXCollections fx:factory="observableArrayList" />
									</items>
								</ComboBox>
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="ISIN"
									GridPane.columnIndex="2" GridPane.rowIndex="1" />
								<TextField fx:id="isin" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="3" GridPane.rowIndex="1" />
								<Label fx:id="isinLabel" GridPane.columnIndex="3" GridPane.rowIndex="1" />
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Trading size"
									GridPane.rowIndex="1" />
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Total isued"
									GridPane.rowIndex="2" />
								<Label fx:id="dividendCurrencyLabel" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									text="Dividend currency" visible="false" GridPane.columnIndex="4"
									GridPane.rowIndex="2" />
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Currency"
									GridPane.columnIndex="2" GridPane.rowIndex="5" />
								<ComboBox fx:id="currency" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="3" GridPane.rowIndex="5">
									<items>
										<FXCollections fx:factory="observableArrayList" />
									</items>
								</ComboBox>
								<TextField fx:id="tradingSize" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="1" GridPane.rowIndex="1" />
								<TextField fx:id="totalIssued" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="1" GridPane.rowIndex="2" />
								<DatePicker fx:id="issueDate" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="1" GridPane.rowIndex="3" />
								<TextField fx:id="issuePrice" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="1" GridPane.rowIndex="4" />
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Issue price"
									GridPane.rowIndex="4" />
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Issue date"
									GridPane.rowIndex="3" />
								<CheckBox fx:id="payDividend" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									mnemonicParsing="false" text="Pay Dividend"
									GridPane.columnIndex="4" GridPane.rowIndex="1" />
								<Label fx:id="dividendFrequencyLabel" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									text="Dividend frequency" visible="false" GridPane.columnIndex="4"
									GridPane.rowIndex="3" />
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Active from"
									GridPane.columnIndex="2" GridPane.rowIndex="2" />
								<DatePicker fx:id="activeFrom" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="3" GridPane.rowIndex="2" />
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Active to"
									GridPane.columnIndex="2" GridPane.rowIndex="3" />
								<DatePicker fx:id="activeTo" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="3" GridPane.rowIndex="3" />
								<ComboBox fx:id="dividendCurrency" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									visible="false" GridPane.columnIndex="5" GridPane.rowIndex="2">
									<items>
										<FXCollections fx:factory="observableArrayList" />
									</items>
								</ComboBox>
								<ComboBox fx:id="dividendFrequency" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									visible="false" GridPane.columnIndex="5" GridPane.rowIndex="3">
									<items>
										<FXCollections fx:factory="observableArrayList" />
									</items>
								</ComboBox>
								<Label maxHeight="-Infinity" maxWidth="-Infinity"
									minHeight="-Infinity" minWidth="-Infinity" text="Exchange"
									GridPane.rowIndex="5" />
								<ComboBox fx:id="exchange" maxHeight="-Infinity"
									maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
									GridPane.columnIndex="1" GridPane.rowIndex="5" />
								<Label fx:id="exchangeLabel" GridPane.columnIndex="1" GridPane.rowIndex="5" />
							</children>
							<padding>
								<Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
							</padding>
						</GridPane>
					</content>
				</Tab>
				<Tab text="Ratings">
					<content>
						<VBox spacing="10">
							<padding>
								<Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
							</padding>
							<TableView fx:id="ratingsTable">
								<columns>
									<TableColumn fx:id="agencyCol" text="Agency" prefWidth="150" />
									<TableColumn fx:id="ratingCol" text="Rating Code" prefWidth="150" />
									<TableColumn fx:id="fromCol" text="Valid From" prefWidth="150" />
									<TableColumn fx:id="toCol" text="Valid To" prefWidth="150" />
								</columns>
							</TableView>
							<HBox spacing="10">
								<Button fx:id="removeRatingButton" mnemonicParsing="false" onAction="#removeRating" text="Remove" />
							</HBox>
							<GridPane hgap="10" vgap="10">
								<padding>
									<Insets bottom="10.0" left="10.0" right="10.0" top="20.0" />
								</padding>
								<Label text="Agency:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
								<ComboBox fx:id="agencyComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0" />
								<Label text="Rating:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
								<ComboBox fx:id="ratingComboBox" GridPane.columnIndex="3" GridPane.rowIndex="0" />
								<Label text="Valid From:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
								<DatePicker fx:id="validFromPicker" GridPane.columnIndex="1" GridPane.rowIndex="1" />
								<Label text="Valid To:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
								<DatePicker fx:id="validToPicker" GridPane.columnIndex="3" GridPane.rowIndex="1" />
								<Button fx:id="addRatingButton" mnemonicParsing="false" onAction="#addRating" text="Add" GridPane.columnIndex="4" GridPane.rowIndex="1" />
							</GridPane>
						</VBox>
					</content>
				</Tab>
			</tabs>
		</TabPane>
	</children>
	<padding>
		<Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
	</padding>
</GridPane>
